<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <application
        android:name=".LuoShuApplication"
        android:allowBackup="false"
        android:hardwareAccelerated="true"
        android:icon="@mipmap/ic_luoshu"
        android:roundIcon="@mipmap/ic_luoshu"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.LuoShuHybrid"
        android:usesCleartextTraffic="false">

        <!-- Optional Vector/LSPosed bridge for applications that bundle fonts in their own APK. -->
        <meta-data
            android:name="xposedmodule"
            android:value="true" />
        <meta-data
            android:name="xposeddescription"
            android:value="洛书应用内置字体桥接：让 Play 商店、系统时钟等 APK 自带字体跟随当前洛书字体" />
        <meta-data
            android:name="xposedminversion"
            android:value="82" />

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".TaskCenterActivity"
            android:exported="false" />

        <service
            android:name=".NativeImportForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync"
            android:stopWithTask="false" />

        <receiver
            android:name=".NativeImportActionReceiver"
            android:exported="false" />
    </application>

</manifest>
