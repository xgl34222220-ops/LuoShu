#!/system/bin/sh
# 洛书 GMS 字体组件恢复器。
# 旧测试版曾临时禁用 GMS FontsProvider；真机确认目标应用使用 APK 内置字体后，
# 新版只负责恢复旧状态，不再修改 GMS 字体服务。
set +e

MODDIR="${MODDIR:-${0%/*}/..}"
STATE_FILE="${PLAY_FONT_STATE:-$MODDIR/config/play_font_bridge.conf}"
LOG_FILE="${PLAY_FONT_LOG:-$MODDIR/logs/play-font-bridge.log}"
PM_BIN="${LUOSHU_PM:-pm}"
DUMPSYS_BIN="${LUOSHU_DUMPSYS:-dumpsys}"

GMS_PACKAGE='com.google.android.gms'
PROVIDER_COMPONENT='com.google.android.gms/com.google.android.gms.fonts.provider.FontsProvider'
UPDATER_COMPONENT='com.google.android.gms/com.google.android.gms.fonts.update.UpdateSchedulerService'

_bridge_log() {
    mkdir -p "${LOG_FILE%/*}" 2>/dev/null || true
    printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo unknown)" "$1" >> "$LOG_FILE" 2>/dev/null || true
}

_pm() {
    "$PM_BIN" "$@"
}

_gms_installed() {
    _pm path "$GMS_PACKAGE" >/dev/null 2>&1
}

_restore_component() {
    _user="$1"
    _component="$2"
    _pm default-state --user "$_user" "$_component" >/dev/null 2>&1 || \
        _pm enable --user "$_user" "$_component" >/dev/null 2>&1 || true
}

_restore() {
    [ -f "$STATE_FILE" ] || {
        _bridge_log 'GMS 字体组件保持系统默认状态'
        printf 'provider-preserved\n'
        return 0
    }

    _restored=0
    while IFS='|' read -r _user _component _state; do
        case "$_user" in version=*) continue ;; esac
        [ -n "$_user" ] && [ -n "$_component" ] || continue
        _restore_component "$_user" "$_component"
        _restored=$((_restored + 1))
    done < "$STATE_FILE"

    rm -f "$STATE_FILE" 2>/dev/null || true
    _bridge_log "已恢复 $_restored 个旧测试版修改的 GMS 字体组件；应用内置字体改由运行时 Hook 处理"
    printf 'restored=%s\n' "$_restored"
}

_status() {
    printf 'installed=%s\n' "$(_gms_installed && echo true || echo false)"
    printf 'stateFile=%s\n' "$([ -f "$STATE_FILE" ] && echo true || echo false)"
    printf 'providerComponent=%s\n' "$PROVIDER_COMPONENT"
    printf 'updaterComponent=%s\n' "$UPDATER_COMPONENT"
    printf 'mode=preserve-provider\n'
    if [ -f "$STATE_FILE" ]; then
        printf 'pendingRestore:\n'
        sed -n '/^[0-9][0-9]*|/p' "$STATE_FILE" 2>/dev/null | sed 's/^/  /'
    fi
    if command -v "$DUMPSYS_BIN" >/dev/null 2>&1; then
        printf 'dumpsysFontEntries:\n'
        "$DUMPSYS_BIN" package "$GMS_PACKAGE" 2>/dev/null | grep -i 'fonts' | head -n 80 | sed 's/^/  /'
    fi
}

case "${1:-status}" in
    apply|restore) _restore ;;
    status) _status ;;
    *) echo 'usage: play_font_bridge apply|restore|status' >&2; exit 2 ;;
esac
