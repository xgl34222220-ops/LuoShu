#!/system/bin/sh
# 洛书 v13.6 Beta6 - Android 16 / GMS、Google 与 Gemini 动态字体桥接
# ColorOS 临时 bind 动态字体；HyperOS 关闭 GMS 动态字体提供器，
# 让 Play 回退到已经替换的系统 sans-serif，不删除动态字体文件。

set +e

MODDIR="${MODDIR:-/data/adb/modules/LuoShu}"
LOG_FILE="$MODDIR/logs/fontswitch.log"
ACTION="${1:-now}"
BRIDGE_DATA_DIR="${BRIDGE_DATA_DIR:-/data/fonts/luoshu}"
GLOBAL_STATE_DIR="${GLOBAL_STATE_DIR:-/data/adb/luoshu}"
COMPONENT_STATE_FILE="$GLOBAL_STATE_DIR/gms_font_components.conf"
GMS_FONTS_PROVIDER="com.google.android.gms/com.google.android.gms.fonts.provider.FontsProvider"
GMS_FONTS_UPDATER="com.google.android.gms/com.google.android.gms.fonts.update.UpdateSchedulerService"

bridge_log() {
    mkdir -p "$MODDIR/logs" 2>/dev/null || true
    echo "[$(date '+%Y-%m-%d %H:%M:%S' 2>/dev/null)] [GMS-BRIDGE] $*" >> "$LOG_FILE" 2>/dev/null || true
}

is_hyperos() {
    [ -n "$(getprop ro.mi.os.version.name 2>/dev/null)" ] || \
        [ -n "$(getprop ro.miui.ui.version.name 2>/dev/null)" ]
}

normalize_component_state() {
    _state=$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | tail -n1)
    case "$_state" in
        *disabled-until-used*|*disabled_until_used*|4) echo disabled-until-used ;;
        *disabled-user*|*disabled_user*|3) echo disabled-user ;;
        *disabled*|2) echo disabled ;;
        *enabled*|1) echo enabled ;;
        *default*|0|'') echo default ;;
        *) echo default ;;
    esac
}

get_component_state() {
    _component="$1"
    _value=$(cmd package get-component-enabled-setting --user 0 "$_component" 2>/dev/null)
    [ -n "$_value" ] || _value=$(pm get-component-enabled-setting --user 0 "$_component" 2>/dev/null)
    normalize_component_state "$_value"
}

save_component_states_once() {
    [ -f "$COMPONENT_STATE_FILE" ] && return 0
    mkdir -p "$GLOBAL_STATE_DIR" 2>/dev/null || return 1
    chmod 0700 "$GLOBAL_STATE_DIR" 2>/dev/null || true
    {
        echo "provider=$(get_component_state "$GMS_FONTS_PROVIDER")"
        echo "updater=$(get_component_state "$GMS_FONTS_UPDATER")"
    } > "$COMPONENT_STATE_FILE" 2>/dev/null || return 1
    chmod 0600 "$COMPONENT_STATE_FILE" 2>/dev/null || true
    bridge_log "已保存 GMS 字体组件原始状态"
}

disable_component() {
    _component="$1"
    pm disable --user 0 "$_component" >/dev/null 2>&1 && return 0
    pm disable "$_component" >/dev/null 2>&1 && return 0
    cmd package set-enabled-setting --user 0 "$_component" disabled >/dev/null 2>&1
}

restore_component() {
    _component="$1"; _state="$2"
    case "$_state" in
        enabled) pm enable --user 0 "$_component" >/dev/null 2>&1 || pm enable "$_component" >/dev/null 2>&1 ;;
        disabled) pm disable --user 0 "$_component" >/dev/null 2>&1 || pm disable "$_component" >/dev/null 2>&1 ;;
        disabled-user) pm disable-user --user 0 "$_component" >/dev/null 2>&1 || pm disable-user "$_component" >/dev/null 2>&1 ;;
        disabled-until-used) pm disable-until-used --user 0 "$_component" >/dev/null 2>&1 || pm disable-until-used "$_component" >/dev/null 2>&1 ;;
        *) pm default-state --user 0 "$_component" >/dev/null 2>&1 || pm default-state "$_component" >/dev/null 2>&1 || pm enable --user 0 "$_component" >/dev/null 2>&1 ;;
    esac
}

restore_gms_component_states() {
    [ -f "$COMPONENT_STATE_FILE" ] || return 0
    _provider_state=$(sed -n 's/^provider=//p' "$COMPONENT_STATE_FILE" 2>/dev/null | head -n1)
    _updater_state=$(sed -n 's/^updater=//p' "$COMPONENT_STATE_FILE" 2>/dev/null | head -n1)
    restore_component "$GMS_FONTS_PROVIDER" "${_provider_state:-default}"
    restore_component "$GMS_FONTS_UPDATER" "${_updater_state:-default}"
    rm -f "$COMPONENT_STATE_FILE" 2>/dev/null || true
    rmdir "$GLOBAL_STATE_DIR" 2>/dev/null || true
    bridge_log "已恢复 GMS 字体组件原始状态"
}

font_size() {
    wc -c < "$1" 2>/dev/null | tr -d '[:space:]'
}

valid_source() {
    [ -f "$1" ] || return 1
    _size=$(font_size "$1")
    case "$_size" in ''|*[!0-9]*) return 1 ;; esac
    [ "$_size" -ge 1024 ]
}

is_variable_font() {
    # OpenType 可变字体包含 fvar 表。grep 只检查二进制表标记，不修改文件。
    grep -a -q 'fvar' "$1" 2>/dev/null
}

same_file_content() {
    [ -f "$1" ] && [ -f "$2" ] || return 1
    _left_size=$(font_size "$1")
    _right_size=$(font_size "$2")
    [ -n "$_left_size" ] && [ "$_left_size" = "$_right_size" ] || return 1
    _left_sum=$(cksum < "$1" 2>/dev/null | awk '{print $1}')
    _right_sum=$(cksum < "$2" 2>/dev/null | awk '{print $1}')
    [ -n "$_left_sum" ] && [ "$_left_sum" = "$_right_sum" ]
}

sync_stable_source() {
    _stable_name="$1"; _stable_src="$2"
    valid_source "$_stable_src" || return 1
    _stable_dst="$BRIDGE_DATA_DIR/$_stable_name"
    if ! same_file_content "$_stable_src" "$_stable_dst"; then
        _stable_tmp="$BRIDGE_DATA_DIR/.${_stable_name}.$$"
        cp -f "$_stable_src" "$_stable_tmp" 2>/dev/null || return 1
        chmod 0644 "$_stable_tmp" 2>/dev/null || true
        chown 0:0 "$_stable_tmp" 2>/dev/null || true
        mv -f "$_stable_tmp" "$_stable_dst" 2>/dev/null || return 1
    fi
    chmod 0644 "$_stable_dst" 2>/dev/null || true
    chown 0:0 "$_stable_dst" 2>/dev/null || true
    return 0
}

prepare_stable_sources() {
    # HyperOS/Zygisk Next 会在应用命名空间隐藏 /data/adb/modules。
    # 只把 3 个字重（可选 1 个可变字体）同步到 Android 字体数据目录，
    # 再从这个不会被元模块隔离的路径执行 bind。
    mkdir -p "$BRIDGE_DATA_DIR" 2>/dev/null || return 1
    chmod 0755 "$BRIDGE_DATA_DIR" 2>/dev/null || true
    chown 0:0 "$BRIDGE_DATA_DIR" 2>/dev/null || true
    sync_stable_source regular.font "$MODDIR/config/gms_bridge/regular.font" || return 1
    sync_stable_source medium.font "$MODDIR/config/gms_bridge/medium.font" || return 1
    sync_stable_source bold.font "$MODDIR/config/gms_bridge/bold.font" || return 1
    if valid_source "$MODDIR/config/gms_bridge/variable.font" && is_variable_font "$MODDIR/config/gms_bridge/variable.font"; then
        sync_stable_source variable.font "$MODDIR/config/gms_bridge/variable.font" || true
    else
        rm -f "$BRIDGE_DATA_DIR/variable.font" 2>/dev/null || true
    fi
    if command -v restorecon >/dev/null 2>&1; then
        restorecon -RF "$BRIDGE_DATA_DIR" >/dev/null 2>&1 || true
    elif command -v chcon >/dev/null 2>&1; then
        chcon u:object_r:font_data_file:s0 "$BRIDGE_DATA_DIR" "$BRIDGE_DATA_DIR"/*.font >/dev/null 2>&1 || true
    fi
    bridge_log "稳定桥接源已同步：$BRIDGE_DATA_DIR"
    return 0
}

source_for_name() {
    _name="$1"
    _exact="$MODDIR/system/fonts/$_name"
    case "$_name" in
        *Flex*)
            # Android 16 的 HyperOS Play 会优先使用 GMS 下载的
            # Google_Sans_Flex。先找真正的可变字体；用户字体是普通
            # TTF/OTF 时则回退到常规字重，确保 Play 仍显示所选字形。
            valid_source "$_exact" && is_variable_font "$_exact" && { echo "$_exact"; return 0; }
            _vf="$BRIDGE_DATA_DIR/variable.font"
            valid_source "$_vf" && is_variable_font "$_vf" && { echo "$_vf"; return 0; }
            _vf="$MODDIR/config/gms_bridge/variable.font"
            valid_source "$_vf" && is_variable_font "$_vf" && { echo "$_vf"; return 0; }
            _vf="$MODDIR/system/fonts/GoogleSansFlex-Regular.ttf"
            valid_source "$_vf" && is_variable_font "$_vf" && { echo "$_vf"; return 0; }
            _vf="$MODDIR/system/fonts/RobotoFlex-Regular.ttf"
            valid_source "$_vf" && is_variable_font "$_vf" && { echo "$_vf"; return 0; }
            _fallback="$BRIDGE_DATA_DIR/regular.font"
            valid_source "$_fallback" && { echo "$_fallback"; return 0; }
            _fallback="$MODDIR/config/gms_bridge/regular.font"
            valid_source "$_fallback" && { echo "$_fallback"; return 0; }
            _fallback="$MODDIR/system/fonts/Roboto-Regular.ttf"
            valid_source "$_fallback" && { echo "$_fallback"; return 0; }
            return 1
            ;;
        *Code*) return 1 ;;
        *Bold*|*-700-*) _bridge_weight=bold; _fallback="$MODDIR/system/fonts/Roboto-Bold.ttf" ;;
        *Medium*|*-500-*) _bridge_weight=medium; _fallback="$MODDIR/system/fonts/Roboto-Medium.ttf" ;;
        *) _bridge_weight=regular; _fallback="$MODDIR/system/fonts/Roboto-Regular.ttf" ;;
    esac
    _stable="$BRIDGE_DATA_DIR/${_bridge_weight}.font"
    if valid_source "$_stable"; then
        echo "$_stable"
        return 0
    fi
    if valid_source "$_exact"; then
        echo "$_exact"
        return 0
    fi
    if valid_source "$_fallback"; then
        echo "$_fallback"
        return 0
    fi
    _bridge="$MODDIR/config/gms_bridge/${_bridge_weight}.font"
    valid_source "$_bridge" && echo "$_bridge"
}

if [ "$ACTION" = "resolve" ]; then
    source_for_name "$2"
    exit $?
fi

namespace_pids() {
    {
        echo 1
        pidof zygote64 zygote zygote_ocomp system_server 2>/dev/null
        # HyperOS + Zygisk Next 会从独立 namespace daemon 派生/清理应用命名空间。
        pidof zn-nsdaemon-zygote zn-nsdaemon 2>/dev/null
        package_pids com.android.vending
        package_pids com.google.android.gms
        pidof com.google.android.apps.bard com.google.android.googlequicksearchbox 2>/dev/null
        pidof com.android.chrome com.google.android.webview webview_zygote 2>/dev/null
    } | tr ' ' '\n' | awk '/^[0-9]+$/ && !seen[$0]++'
}

package_pids() {
    _pkg="$1"
    for _cmdline in /proc/[0-9]*/cmdline; do
        [ -r "$_cmdline" ] || continue
        _proc_name=$(tr '\000' '\n' < "$_cmdline" 2>/dev/null | head -n1)
        case "$_proc_name" in
            "$_pkg"|"$_pkg":*) echo "${_cmdline#/proc/}" | cut -d/ -f1 ;;
        esac
    done
}

namespace_process_name() {
    tr '\000' '\n' < "/proc/$1/cmdline" 2>/dev/null | head -n1
}

record_namespace_result() {
    _result_pid="$1"; _result_ok="$2"
    _result_name=$(namespace_process_name "$_result_pid")
    case "$_result_name" in
        com.android.vending|com.android.vending:*)
            PLAY_NS_SEEN=$((PLAY_NS_SEEN + 1))
            if [ "$_result_ok" -eq 1 ]; then PLAY_NS_OK=$((PLAY_NS_OK + 1)); else PLAY_NS_FAIL=$((PLAY_NS_FAIL + 1)); fi
            ;;
        com.google.android.gms|com.google.android.gms:*)
            GMS_NS_SEEN=$((GMS_NS_SEEN + 1))
            if [ "$_result_ok" -eq 1 ]; then GMS_NS_OK=$((GMS_NS_OK + 1)); else GMS_NS_FAIL=$((GMS_NS_FAIL + 1)); fi
            ;;
    esac
}

namespace_file_id() {
    _ns_pid="$1"
    _ns_path="$2"
    if command -v nsenter >/dev/null 2>&1; then
        nsenter -t "$_ns_pid" -m -- stat -c '%d:%i' "$_ns_path" 2>/dev/null
    else
        stat -c '%d:%i' "$_ns_path" 2>/dev/null
    fi
}

namespace_source_path() {
    _ns_pid="$1"
    _ns_src="$2"
    # KernelSU/Zygisk Next 的应用命名空间可能隐藏 /data/adb/modules。
    # /proc/1/root 始终从 init 的挂载视图解析真实桥接源。
    if [ "$_ns_pid" != 1 ] && [ -f "/proc/1/root$_ns_src" ]; then
        printf '/proc/1/root%s\n' "$_ns_src"
    else
        printf '%s\n' "$_ns_src"
    fi
}

namespace_has_source() {
    _ns_pid="$1"; _ns_src="$2"; _ns_target="$3"
    _ns_source_id=$(namespace_file_id "$_ns_pid" "$_ns_src")
    _ns_target_id=$(namespace_file_id "$_ns_pid" "$_ns_target")
    [ -n "$_ns_source_id" ] && [ "$_ns_source_id" = "$_ns_target_id" ]
}

do_bind() {
    _src="$1"
    _target="$2"
    _ok=0
    # KernelSU/Zygisk Next 可能让 Play、GMS、zygote 处于不同挂载命名空间。
    # 对已知关键进程逐个挂载，不能只改 PID 1。
    if command -v nsenter >/dev/null 2>&1; then
        for _pid in $(namespace_pids); do
            _ns_src=$(namespace_source_path "$_pid" "$_src")
            if namespace_has_source "$_pid" "$_ns_src" "$_target"; then
                record_namespace_result "$_pid" 1
                _ok=1
                continue
            fi
            nsenter -t "$_pid" -m -- mount --bind "$_ns_src" "$_target" >/dev/null 2>&1 || \
                nsenter -t "$_pid" -m -- /system/bin/mount -o bind "$_ns_src" "$_target" >/dev/null 2>&1
            if namespace_has_source "$_pid" "$_ns_src" "$_target"; then
                record_namespace_result "$_pid" 1
                _ok=1
            else
                record_namespace_result "$_pid" 0
                _proc_name=$(namespace_process_name "$_pid")
                case "$_proc_name" in
                    com.android.vending*|com.google.android.gms*)
                        bridge_log "命名空间挂载失败 pid=$_pid process=$_proc_name target=${_target##*/} source=$_ns_src"
                        ;;
                esac
            fi
        done
    fi
    _self_id=$(stat -c '%d:%i' "$_src" 2>/dev/null)
    _target_id=$(stat -c '%d:%i' "$_target" 2>/dev/null)
    if [ -n "$_self_id" ] && [ "$_self_id" = "$_target_id" ]; then
        _ok=1
    else
        mount --bind "$_src" "$_target" >/dev/null 2>&1 || /system/bin/mount -o bind "$_src" "$_target" >/dev/null 2>&1
        _target_id=$(stat -c '%d:%i' "$_target" 2>/dev/null)
        [ -n "$_self_id" ] && [ "$_self_id" = "$_target_id" ] && _ok=1
    fi
    [ "$_ok" -eq 1 ]
}

do_umount() {
    _target="$1"
    if command -v nsenter >/dev/null 2>&1; then
        for _pid in $(namespace_pids); do
            nsenter -t "$_pid" -m -- umount "$_target" >/dev/null 2>&1 || true
        done
    fi
    umount "$_target" >/dev/null 2>&1
}

stop_watcher() {
    _watch_pid_file="$MODDIR/config/gms_bridge/watch.pid"
    _watch_pid=$(cat "$_watch_pid_file" 2>/dev/null)
    case "$_watch_pid" in ''|*[!0-9]*) _watch_pid= ;; esac
    if [ -n "$_watch_pid" ] && [ "$_watch_pid" != "$$" ]; then
        kill "$_watch_pid" >/dev/null 2>&1 || true
    fi
    rm -f "$_watch_pid_file" 2>/dev/null || true
}

watch_play_namespace() {
    if is_hyperos; then
        bridge_log "HyperOS 已使用系统字体回退模式，不启动命名空间守护"
        exit 0
    fi
    _watch_dir="$MODDIR/config/gms_bridge"
    _watch_pid_file="$_watch_dir/watch.pid"
    mkdir -p "$_watch_dir" 2>/dev/null || exit 0
    _old_pid=$(cat "$_watch_pid_file" 2>/dev/null)
    case "$_old_pid" in ''|*[!0-9]*) _old_pid= ;; esac
    if [ -n "$_old_pid" ] && kill -0 "$_old_pid" >/dev/null 2>&1; then
        _old_cmd=$(tr '\000' ' ' < "/proc/$_old_pid/cmdline" 2>/dev/null)
        case "$_old_cmd" in *play_font_bridge*watch*) exit 0 ;; esac
    fi
    printf '%s\n' "$$" > "$_watch_pid_file" 2>/dev/null || exit 0
    trap 'rm -f "$MODDIR/config/gms_bridge/watch.pid" 2>/dev/null' EXIT
    trap 'rm -f "$MODDIR/config/gms_bridge/watch.pid" 2>/dev/null; exit 0' HUP INT TERM
    bridge_log "Play 命名空间守护已启动 pid=$$"
    _last_consumers="__start__"
    _watch_tick=60
    while [ -f "$MODDIR/module.prop" ] && [ ! -e "$MODDIR/remove" ] && [ ! -e "$MODDIR/disable" ]; do
        _play_pids=$(package_pids com.android.vending | sort -n | tr '\n' ',')
        _gms_pids=$(package_pids com.google.android.gms | sort -n | tr '\n' ',')
        _consumers="play=${_play_pids};gms=${_gms_pids}"
        _watch_tick=$((_watch_tick + 1))
        if [ "$_consumers" != "$_last_consumers" ] || [ "$_watch_tick" -ge 60 ]; then
            if [ -n "$_play_pids$_gms_pids" ]; then
                bridge_log "检测到 Play/GMS 命名空间变化：${_last_consumers:-无} -> $_consumers"
                MODDIR="$MODDIR" sh "$0" now >/dev/null 2>&1 || true
            fi
            _last_consumers="$_consumers"
            _watch_tick=0
        fi
        sleep 5
    done
}

restore_mounts() {
    _restored=0
    for _target in /data/fonts/files/*/GoogleSans*.ttf; do
        [ -f "$_target" ] || continue
        do_umount "$_target" && _restored=$((_restored + 1))
    done
    for _target in /data/user/*/com.google.android.gms/files/fonts/opentype/Google_Sans*.ttf; do
        [ -f "$_target" ] || continue
        do_umount "$_target" && _restored=$((_restored + 1))
    done
    rm -rf "$BRIDGE_DATA_DIR" 2>/dev/null || true
    restore_gms_component_states
    bridge_log "恢复动态 Google Sans 挂载：$_restored"
}

restart_hyperos_font_consumers_once() {
    _miui=$(getprop ro.mi.os.version.name 2>/dev/null)
    [ -n "$_miui" ] || return 0
    _boot_id=$(cat /proc/sys/kernel/random/boot_id 2>/dev/null)
    [ -n "$_boot_id" ] || _boot_id="$(date +%s 2>/dev/null)-$$"
    _marker="$MODDIR/config/gms_bridge/restart.boot"
    [ "$(cat "$_marker" 2>/dev/null)" = "$_boot_id" ] && return 0
    printf '%s\n' "$_boot_id" > "$_marker" 2>/dev/null || true
    # FontsProvider 已禁用后，只需重建 Play 进程并关闭它持有的旧字体 FD。
    # 不强停整个 GMS，避免影响账号、推送和其他核心服务。
    am force-stop com.android.vending >/dev/null 2>&1 || true
    bridge_log "HyperOS 已单次重置 Play 字体进程"
}

apply_hyperos_system_fallback() {
    mkdir -p "$MODDIR/config/gms_bridge" 2>/dev/null || true
    save_component_states_once || bridge_log "GMS 字体组件原始状态保存失败，将按默认状态恢复"
    _provider_ok=0
    _updater_ok=0
    disable_component "$GMS_FONTS_PROVIDER" && _provider_ok=1
    disable_component "$GMS_FONTS_UPDATER" && _updater_ok=1
    {
        echo "mode=hyperos-system-fallback"
        echo "provider_disabled=$_provider_ok"
        echo "updater_disabled=$_updater_ok"
    } > "$MODDIR/config/gms_bridge/runtime.status" 2>/dev/null || true
    bridge_log "HyperOS Play 系统字体回退：FontsProvider=$_provider_ok UpdateScheduler=$_updater_ok"
    if [ "$_provider_ok" -eq 1 ]; then
        restart_hyperos_font_consumers_once
        return 0
    fi
    bridge_log "FontsProvider 禁用失败，继续尝试动态字体 bind 兼容路径"
    return 1
}

[ "$ACTION" = "restore" ] && { stop_watcher; restore_mounts; exit 0; }
[ "$ACTION" = "watch" ] && { watch_play_namespace; exit 0; }

# HyperOS 的 Play 通过 GMS FontsProvider 返回私有目录中的字体 FD。
# 这些文件带有 GMS 专属 uid、0600 权限和 SELinux 类别；root 的 bind
# 校验成功并不代表 FontsProvider 自身能读取替换后的 inode。禁用 provider
# 与更新调度后，Play 会回退到洛书已经替换的系统 sans-serif 字体。
if is_hyperos && apply_hyperos_system_fallback; then
    exit 0
fi

if ! prepare_stable_sources; then
    bridge_log "稳定桥接源同步失败，回退到模块内源"
fi

_attempts=1
[ "$ACTION" = "boot" ] && _attempts=9
_attempt=1

while [ "$_attempt" -le "$_attempts" ]; do
    _found=0
    _mounted=0
    _skipped=0
    _failed=0
    PLAY_NS_SEEN=0; PLAY_NS_OK=0; PLAY_NS_FAIL=0
    GMS_NS_SEEN=0; GMS_NS_OK=0; GMS_NS_FAIL=0
    for _target in \
        /data/fonts/files/*/GoogleSans*.ttf \
        /data/fonts/files/*/Google_Sans*.ttf \
        /data/user/*/com.google.android.gms/files/fonts/opentype/Google_Sans*.ttf \
        /data/user/*/com.google.android.gms/files/fonts/opentype/GoogleSans*.ttf; do
        [ -f "$_target" ] || continue
        _found=$((_found + 1))
        _name=$(basename "$_target")
        _src=$(source_for_name "$_name")
        if [ -z "$_src" ]; then
            _failed=$((_failed + 1))
            continue
        fi
        case "$_name" in
            *Code*)
                _skipped=$((_skipped + 1))
                bridge_log "保留 $_name 原版：代码字体不使用正文字体替换"
                continue
                ;;
            *Flex*)
                if is_variable_font "$_src"; then
                    bridge_log "桥接 $_name：使用可变字体源"
                else
                    bridge_log "桥接 $_name：使用常规字体兼容源"
                fi
                ;;
        esac
        if do_bind "$_src" "$_target"; then
            _mounted=$((_mounted + 1))
        else
            _failed=$((_failed + 1))
        fi
    done

    if [ "$_found" -gt 0 ]; then
        bridge_log "动态 Google Sans：发现=$_found 成功=$_mounted 跳过=$_skipped 失败=$_failed"
        bridge_log "Play/GMS 命名空间验证：Play 实例=$PLAY_NS_SEEN 成功=$PLAY_NS_OK 失败=$PLAY_NS_FAIL；GMS 实例=$GMS_NS_SEEN 成功=$GMS_NS_OK 失败=$GMS_NS_FAIL"
        {
            echo "found=$_found"
            echo "mounted=$_mounted"
            echo "failed=$_failed"
            echo "play_seen=$PLAY_NS_SEEN"
            echo "play_ok=$PLAY_NS_OK"
            echo "play_failed=$PLAY_NS_FAIL"
            echo "gms_seen=$GMS_NS_SEEN"
            echo "gms_ok=$GMS_NS_OK"
            echo "gms_failed=$GMS_NS_FAIL"
        } > "$MODDIR/config/gms_bridge/runtime.status" 2>/dev/null || true
        if [ "$_mounted" -gt 0 ]; then
            cmd font system --update >/dev/null 2>&1 || true
            # 只在开机初次准备时重建一次缓存；守护补挂载不反复杀进程。
            [ "$ACTION" = "boot" ] && restart_hyperos_font_consumers_once
        fi
        exit 0
    fi

    [ "$_attempt" -lt "$_attempts" ] && sleep 10
    _attempt=$((_attempt + 1))
done

bridge_log "动态 Google Sans：两个已知目录均未发现目标文件"
exit 0
