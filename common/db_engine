#!/system/bin/sh
# LuoShu v13.6 Beta1 - direct file mapping engine
# This file intentionally has no .sh suffix so third-party module scanners do not
# classify it as a custom shell hook.
set +e

DB_MODDIR="${MODDIR:-${MODULE_DIR:-/data/adb/modules/LuoShu}}"
DB_CONFIG="$DB_MODDIR/config"
DB_ROOT="$DB_MODDIR/direct_map"
DB_GENS="$DB_ROOT/gens"
DB_MANIFEST="$DB_ROOT/current.map"
DB_STATUS="$DB_CONFIG/direct_map_status.conf"
DB_LOG="$DB_MODDIR/logs/direct_map.log"

_luoshu_db_log() {
    command mkdir -p "${DB_LOG%/*}" 2>/dev/null || true
    printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo unknown)" "$1" >> "$DB_LOG" 2>/dev/null || true
}

_luoshu_db_detect_hybrid() {
    [ "${LUOSHU_DB_TEST_HYBRID:-0}" = "1" ] && return 0
    [ -d /data/adb/hybrid_mount ] || [ -d /data/adb/hybridmount ] || \
    [ -e /data/adb/modules/.hybrid_mount ] || [ -d /data/adb/modules/HybridMount ] && return 0
    for _p in /data/adb/modules/*/module.prop; do
        [ -f "$_p" ] || continue
        if grep -Eiq '^(id|name)=.*hybrid[ _-]*mount' "$_p" 2>/dev/null; then return 0; fi
    done
    return 1
}

luoshu_db_mode() {
    _mode="${LUOSHU_DB_MODE:-}"
    [ -n "$_mode" ] || _mode=$(head -n1 "$DB_CONFIG/mount_mode.conf" 2>/dev/null | tr -d '\r\n')
    case "$_mode" in
        direct|module) printf '%s\n' "$_mode"; return 0 ;;
    esac
    if _luoshu_db_detect_hybrid; then printf '%s\n' direct; else printf '%s\n' module; fi
}

luoshu_db_use_direct() { [ "$(luoshu_db_mode)" = "direct" ]; }

_luoshu_db_size() {
    _n=$(wc -c < "$1" 2>/dev/null | tr -d '[:space:]')
    case "$_n" in ''|*[!0-9]*) _n=0 ;; esac
    printf '%s\n' "$_n"
}

_luoshu_db_key() {
    _size=$(_luoshu_db_size "$1")
    _sum=$(cksum < "$1" 2>/dev/null | awk '{print $1}')
    [ -n "$_sum" ] || _sum=$(basename "$1" | cksum | awk '{print $1}')
    printf '%s_%s\n' "$_sum" "$_size"
}

luoshu_db_begin() {
    command mkdir -p "$DB_CONFIG" "$DB_GENS" "$DB_MODDIR/logs" 2>/dev/null || return 1
    DB_BUILD_ID="$(date +%s 2>/dev/null || echo 0)_$$"
    DB_BUILD_DIR="$DB_GENS/$DB_BUILD_ID"
    DB_BUILD_MAP="$DB_ROOT/.current.map.$$"
    command mkdir -p "$DB_BUILD_DIR" 2>/dev/null || return 1
    : > "$DB_BUILD_MAP" || return 1
    DB_BUILD_COUNT=0
    export DB_BUILD_ID DB_BUILD_DIR DB_BUILD_MAP DB_BUILD_COUNT
}

_luoshu_db_payload() {
    _src="$1"
    _key=$(_luoshu_db_key "$_src")
    _dst="$DB_BUILD_DIR/${_key}.font"
    if [ ! -s "$_dst" ]; then
        cp -f "$_src" "$_dst" 2>/dev/null || return 1
        chmod 0644 "$_dst" 2>/dev/null || true
        command -v chcon >/dev/null 2>&1 && chcon u:object_r:system_file:s0 "$_dst" 2>/dev/null || true
    fi
    printf '%s\n' "$_dst"
}

luoshu_db_add() {
    _src="$1"; _target="$2"
    [ -s "$_src" ] || return 1
    [ -f "$_target" ] || return 0
    _size=$(_luoshu_db_size "$_src")
    [ "$_size" -ge 1024 ] 2>/dev/null || return 1
    grep -Fq "|$_target" "$DB_BUILD_MAP" 2>/dev/null && return 0
    _payload=$(_luoshu_db_payload "$_src") || return 1
    printf '%s|%s\n' "$_payload" "$_target" >> "$DB_BUILD_MAP" || return 1
    DB_BUILD_COUNT=$((DB_BUILD_COUNT + 1))
    export DB_BUILD_COUNT
}

luoshu_db_finish() {
    [ -n "$DB_BUILD_MAP" ] && [ -f "$DB_BUILD_MAP" ] || return 1
    if [ "$DB_BUILD_COUNT" -le 0 ] 2>/dev/null; then
        rm -rf "$DB_BUILD_DIR" "$DB_BUILD_MAP" 2>/dev/null || true
        _luoshu_db_log "refused empty mapping"
        return 1
    fi
    mv -f "$DB_BUILD_MAP" "$DB_MANIFEST" 2>/dev/null || return 1
    chmod 0644 "$DB_MANIFEST" 2>/dev/null || true
    {
        printf 'mode=direct\n'
        printf 'state=prepared\n'
        printf 'generation=%s\n' "$DB_BUILD_ID"
        printf 'targets=%s\n' "$DB_BUILD_COUNT"
        printf 'time=%s\n' "$(date +%s 2>/dev/null || echo 0)"
    } > "$DB_STATUS" 2>/dev/null || true
    _luoshu_db_log "prepared generation=$DB_BUILD_ID targets=$DB_BUILD_COUNT"
    return 0
}

_luoshu_db_global() {
    if command -v nsenter >/dev/null 2>&1 && [ -e /proc/1/ns/mnt ]; then
        nsenter -t 1 -m -- "$@"
    else
        "$@"
    fi
}

_luoshu_db_attached() {
    _target="$1"
    grep -F " $_target " /proc/1/mountinfo >/dev/null 2>&1 || grep -F " $_target " /proc/self/mountinfo >/dev/null 2>&1
}

_luoshu_db_attach() {
    _src="$1"; _target="$2"
    _luoshu_db_attached "$_target" && return 0
    _luoshu_db_global /system/bin/mount -o bind "$_src" "$_target" >/dev/null 2>&1 && return 0
    _luoshu_db_global /system/bin/mount --bind "$_src" "$_target" >/dev/null 2>&1 && return 0
    _luoshu_db_global /system/bin/toybox mount -o bind "$_src" "$_target" >/dev/null 2>&1 && return 0
    return 1
}

luoshu_db_apply() {
    luoshu_db_use_direct || return 0
    _active=$(head -n1 "$DB_CONFIG/active_font.conf" 2>/dev/null | tr -d '\r\n')
    if [ -z "$_active" ] || [ "$_active" = "default" ]; then
        {
            printf 'mode=direct\nstate=default\ntargets=0\napplied=0\nfailed=0\ntime=%s\n' "$(date +%s 2>/dev/null || echo 0)"
        } > "$DB_STATUS" 2>/dev/null || true
        return 0
    fi
    [ -s "$DB_MANIFEST" ] || { _luoshu_db_log "manifest missing for active=$_active"; return 1; }
    _total=0; _applied=0; _failed=0
    while IFS='|' read -r _src _target; do
        [ -n "$_src" ] && [ -n "$_target" ] || continue
        _total=$((_total + 1))
        if [ ! -s "$_src" ] || [ ! -f "$_target" ]; then
            _failed=$((_failed + 1)); continue
        fi
        if _luoshu_db_attach "$_src" "$_target"; then
            _applied=$((_applied + 1))
        else
            _failed=$((_failed + 1))
            _luoshu_db_log "attach failed target=$_target"
        fi
    done < "$DB_MANIFEST"
    {
        printf 'mode=direct\nstate=%s\ntargets=%s\napplied=%s\nfailed=%s\ntime=%s\n' \
            "$([ "$_failed" -eq 0 ] && echo active || echo partial)" "$_total" "$_applied" "$_failed" "$(date +%s 2>/dev/null || echo 0)"
    } > "$DB_STATUS" 2>/dev/null || true
    _luoshu_db_log "apply active=$_active targets=$_total applied=$_applied failed=$_failed"
    [ "$_failed" -eq 0 ]
}

luoshu_db_verify() {
    luoshu_db_use_direct || return 0
    _active=$(head -n1 "$DB_CONFIG/active_font.conf" 2>/dev/null | tr -d '\r\n')
    [ -n "$_active" ] && [ "$_active" != "default" ] || return 0
    [ -s "$DB_MANIFEST" ] || return 1
    _bad=0
    while IFS='|' read -r _src _target; do
        [ -n "$_target" ] || continue
        _luoshu_db_attached "$_target" || _bad=$((_bad + 1))
    done < "$DB_MANIFEST"
    [ "$_bad" -eq 0 ]
}

luoshu_db_cleanup() {
    _keep=""
    [ -s "$DB_MANIFEST" ] && _keep=$(head -n1 "$DB_MANIFEST" 2>/dev/null | cut -d/ -f7)
    for _d in "$DB_GENS"/*; do
        [ -d "$_d" ] || continue
        [ "${_d##*/}" = "$_keep" ] && continue
        rm -rf "$_d" 2>/dev/null || true
    done
}

luoshu_db_status_json() {
    _mode=$(luoshu_db_mode)
    _state=$(sed -n 's/^state=//p' "$DB_STATUS" 2>/dev/null | head -n1)
    _targets=$(sed -n 's/^targets=//p' "$DB_STATUS" 2>/dev/null | head -n1)
    _applied=$(sed -n 's/^applied=//p' "$DB_STATUS" 2>/dev/null | head -n1)
    _failed=$(sed -n 's/^failed=//p' "$DB_STATUS" 2>/dev/null | head -n1)
    printf '{"mode":"%s","state":"%s","targets":%s,"applied":%s,"failed":%s}' \
        "$_mode" "${_state:-idle}" "${_targets:-0}" "${_applied:-0}" "${_failed:-0}"
}

case "${0##*/}" in
    db_engine)
        case "${1:-status}" in
            mode) luoshu_db_mode ;;
            apply) luoshu_db_apply ;;
            verify) luoshu_db_verify ;;
            cleanup) luoshu_db_cleanup ;;
            status) luoshu_db_status_json ;;
            *) echo "usage: db_engine {mode|apply|verify|cleanup|status}" >&2; exit 2 ;;
        esac
        ;;
esac
