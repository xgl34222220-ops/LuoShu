#!/system/bin/sh
# 洛书 v13.6 Beta2 - 元模块内容目录兼容层
# 仅同步模块分区负载，不执行 mount/umount，避免 Hybrid Mount 将洛书误判为自定义挂载模块。
set +e

LUOSHU_META_MODDIR="${MODDIR:-${MODULE_DIR:-/data/adb/modules/LuoShu}}"
LUOSHU_META_LOG="${LUOSHU_META_LOG:-$LUOSHU_META_MODDIR/logs/meta_compat.log}"

luoshu_meta_log() {
    _msg="$1"
    mkdir -p "${LUOSHU_META_LOG%/*}" 2>/dev/null || true
    printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo unknown)" "$_msg" >> "$LUOSHU_META_LOG" 2>/dev/null || true
}

luoshu_module_id() {
    _id=$(sed -n 's/^id=//p' "$LUOSHU_META_MODDIR/module.prop" 2>/dev/null | head -n1 | tr -d '\r\n')
    [ -n "$_id" ] || _id=$(basename "$LUOSHU_META_MODDIR")
    printf '%s\n' "$_id"
}

luoshu_detect_meta_engine() {
    _id=$(luoshu_module_id)
    if [ -n "$LUOSHU_META_TEST_ROOT" ]; then
        echo "test-meta"
    elif [ -d "/data/adb/metamodule/mnt/$_id" ] || [ -d "/data/adb/modules/meta-overlay/mnt/$_id" ] || [ -d "/data/adb/modules/meta-overlayfs/mnt/$_id" ]; then
        echo "meta-overlayfs"
    elif [ -d /data/adb/mountify ]; then
        echo "mountify"
    elif [ -d /data/adb/hybrid_mount ] || [ -d /data/adb/hybridmount ] || [ -e /data/adb/modules/.hybrid_mount ] || [ -d /data/adb/modules/HybridMount ]; then
        echo "hybrid-mount"
    elif [ -f "$LUOSHU_META_MODDIR/magic" ]; then
        echo "magic"
    else
        echo "native"
    fi
}

# Hybrid Mount 会在模块根目录写入 mount.error，并在标记存在时拒绝重试。
# 只清理洛书自己目录中的已知标记，不碰其他模块或元模块的全局状态。
luoshu_clear_own_meta_errors() {
    _cleared=0
    for _dir in "$LUOSHU_META_MODDIR" "${LUOSHU_META_OLD_MODDIR:-}"; do
        [ -n "$_dir" ] || continue
        case "$_dir" in /data/adb/modules/LuoShu|/data/adb/modules_update/LuoShu|*/modules/LuoShu|*/modules_update/LuoShu) ;; *) continue ;; esac
        for _marker in "$_dir/mount.error" "$_dir/.mount.error" "$_dir/mount_error"; do
            if [ -e "$_marker" ]; then
                rm -f "$_marker" 2>/dev/null && _cleared=$((_cleared + 1))
            fi
        done
    done
    [ "$_cleared" -gt 0 ] && luoshu_meta_log "已清理洛书旧挂载错误标记：$_cleared"
    return 0
}

# 输出元模块可能读取的内容根目录，每行一个。
# 只处理已经存在且可写的目录，不创建其他元模块的顶层目录。
luoshu_meta_content_roots() {
    _id=$(luoshu_module_id)
    _seen=""

    if [ -n "$LUOSHU_META_TEST_ROOT" ]; then
        printf '%s\n' "$LUOSHU_META_TEST_ROOT/$_id"
        return 0
    fi

    for _base in \
        "${MODULE_CONTENT_DIR:-}" \
        "${META_MODULE_CONTENT_DIR:-}" \
        /data/adb/metamodule/mnt \
        /data/adb/modules/meta-overlay/mnt \
        /data/adb/modules/meta-overlayfs/mnt \
        /data/adb/hybrid_mount/mnt \
        /data/adb/hybridmount/mnt \
        /data/adb/modules/HybridMount/mnt \
        /data/adb/modules/.hybrid_mount/mnt; do
        [ -n "$_base" ] || continue
        [ -d "$_base" ] || continue
        [ -w "$_base" ] || continue
        [ "$_base" = "$LUOSHU_META_MODDIR" ] && continue
        case " $_seen " in *" $_base "*) continue ;; esac
        _seen="$_seen $_base"
        printf '%s\n' "$_base/$_id"
    done
}

luoshu_copy_partition_atomic() {
    _src="$1"
    _dst="$2"
    _parent=${_dst%/*}
    _name=${_dst##*/}
    _tmp="$_parent/.${_name}.luoshu.$$"

    mkdir -p "$_parent" 2>/dev/null || return 1
    rm -rf "$_tmp" 2>/dev/null || true
    if ! cp -af "$_src" "$_tmp" 2>/dev/null; then
        rm -rf "$_tmp" 2>/dev/null || true
        mkdir -p "$_tmp" 2>/dev/null || return 1
        cp -rfp "$_src/." "$_tmp/" 2>/dev/null || { rm -rf "$_tmp" 2>/dev/null; return 1; }
    fi
    rm -rf "$_dst" 2>/dev/null || return 1
    mv "$_tmp" "$_dst" 2>/dev/null || { rm -rf "$_tmp" 2>/dev/null; return 1; }
    chmod -R u=rwX,go=rX "$_dst" 2>/dev/null || true
    return 0
}

luoshu_sync_meta_payload() {
    _engine=$(luoshu_detect_meta_engine)
    _roots=""
    _synced=0
    _failed=0
    _has_payload=0

    for _part in system system_ext product vendor odm oem; do
        _src="$LUOSHU_META_MODDIR/$_part"
        [ -d "$_src" ] || continue
        if find "$_src" -mindepth 1 -print -quit 2>/dev/null | grep -q .; then
            _has_payload=1
            break
        fi
    done

    for _root in $(luoshu_meta_content_roots); do
        [ -n "$_root" ] || continue
        _roots="${_roots}${_roots:+,}$_root"
        # Direct Bind 默认没有分区负载。此时只清掉旧 staging，不创建新的
        # 空内容目录，否则部分元模块仍会尝试 Overlay 并写 mount.error。
        if [ "$_has_payload" -eq 0 ]; then
            if [ -d "$_root" ]; then
                for _part in system system_ext product vendor odm oem; do rm -rf "$_root/$_part" 2>/dev/null || true; done
                rm -f "$_root/.luoshu-payload" 2>/dev/null || true
                rmdir "$_root" 2>/dev/null || true
            fi
            continue
        fi
        mkdir -p "$_root" 2>/dev/null || { _failed=$((_failed + 1)); continue; }
        for _part in system system_ext product vendor odm oem; do
            _src="$LUOSHU_META_MODDIR/$_part"
            _dst="$_root/$_part"
            if [ -d "$_src" ]; then
                if luoshu_copy_partition_atomic "$_src" "$_dst"; then
                    _synced=$((_synced + 1))
                else
                    _failed=$((_failed + 1))
                fi
            else
                rm -rf "$_dst" 2>/dev/null || true
            fi
        done
        printf 'source=%s\ntime=%s\n' "$LUOSHU_META_MODDIR" "$(date +%s)" > "$_root/.luoshu-payload" 2>/dev/null || true
    done

    mkdir -p "$LUOSHU_META_MODDIR/config" 2>/dev/null || true
    {
        printf 'engine=%s\n' "$_engine"
        printf 'roots=%s\n' "$_roots"
        printf 'synced=%s\n' "$_synced"
        printf 'failed=%s\n' "$_failed"
        printf 'time=%s\n' "$(date +%s)"
    } > "$LUOSHU_META_MODDIR/config/meta_compat.conf" 2>/dev/null || true

    if [ "$_failed" -gt 0 ]; then
        luoshu_meta_log "元模块负载同步部分失败：engine=$_engine roots=$_roots synced=$_synced failed=$_failed"
        return 1
    fi
    if [ -n "$_roots" ]; then
        sync 2>/dev/null || true
        luoshu_meta_log "元模块负载同步完成：engine=$_engine roots=$_roots partitions=$_synced"
    else
        luoshu_meta_log "当前环境无需额外内容目录同步：engine=$_engine"
    fi
    return 0
}

luoshu_meta_status_json() {
    _engine=$(luoshu_detect_meta_engine)
    _roots=""
    for _root in $(luoshu_meta_content_roots); do _roots="${_roots}${_roots:+,}$_root"; done
    _conf="$LUOSHU_META_MODDIR/config/meta_compat.conf"
    _last_engine=$(sed -n 's/^engine=//p' "$_conf" 2>/dev/null | head -n1)
    _last_synced=$(sed -n 's/^synced=//p' "$_conf" 2>/dev/null | head -n1)
    _last_failed=$(sed -n 's/^failed=//p' "$_conf" 2>/dev/null | head -n1)
    _last_time=$(sed -n 's/^time=//p' "$_conf" 2>/dev/null | head -n1)
    printf '{"engine":"%s","roots":"%s","lastEngine":"%s","synced":%s,"failed":%s,"time":%s}' \
        "$_engine" "$_roots" "${_last_engine:-$_engine}" "${_last_synced:-0}" "${_last_failed:-0}" "${_last_time:-0}"
}
